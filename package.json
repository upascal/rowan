{
  "name": "markdown-kanban",
  "version": "1.0.0",
  "description": "A standalone macOS task manager that automatically generates a Kanban board from a Markdown to-do list",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "macos": "expo start --macos",
    "build:macos": "expo build:macos",
    "build:web": "expo export:web",
    "deploy": "gh-pages -d cdeb-build",
    "predeploy": "npm run build:web",
    "lint": "eslint .",
    "test": "jest",
    "postbuild:web": "cp web/manifest.json web-build/ && cp web/service-worker.js web-build/ && cp web/offline.html web-build/ && cp web/register-service-worker.js web-build/ && mkdir -p web-build/web && cp -r web/icons web-build/web/"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "expo": "~52.0.37",
    "expo-dev-client": "~5.0.12",
    "expo-file-system": "^18.0.11",
    "expo-router": "^4.0.17",
    "expo-sqlite": "^15.1.2",
    "expo-status-bar": "~2.0.1",
    "lodash": "^4.17.21",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-gesture-handler": "^2.24.0",
    "react-native-reanimated": "^3.17.1",
    "react-native-web": "^0.19.13",
    "remark": "^14.0.3",
    "remark-parse": "^10.0.2",
    "remark-stringify": "^10.0.3",
    "unified": "^10.1.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.16",
    "@types/react": "~18.3.12",
    "@types/uuid": "^10.0.0",
    "gh-pages": "^6.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "@jest/types": "^29.7.0",
    "react-test-renderer": "18.3.1"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/markdown-kanban.git"
  },
  "keywords": [
    "markdown",
    "kanban",
    "task-manager",
    "react-native",
    "macos",
    "expo"
  ],
  "author": "Your Name",
  "license": "MIT"
}
